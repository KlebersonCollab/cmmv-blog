# Security Configuration for RSS Aggregation Package
# Copy this file to .env in your application (apps/api/.env) to override defaults

# XML Parsing Security
SECURITY_XML_MAX_SIZE_MB=10                # Maximum XML feed size in MB
SECURITY_XML_PARSE_TIMEOUT=30000           # XML parsing timeout in milliseconds

# URL Validation Security
SECURITY_URL_MAX_LENGTH=2048               # Maximum URL length in characters

# AI Integration Security
SECURITY_AI_MAX_PROMPT_LENGTH=10000        # Maximum AI prompt length in characters

# JSON Validation Security
SECURITY_JSON_MAX_SIZE=1048576             # Maximum JSON size in bytes (1MB default)
SECURITY_JSON_MAX_DEPTH=10                 # Maximum JSON nesting depth
SECURITY_JSON_MAX_ARRAY_SIZE=1000          # Maximum array size in JSON objects

# Request Body Security
SECURITY_REQUEST_MAX_BODY_SIZE=5242880     # Maximum request body size (5MB default)

# Memory Safety Security
SECURITY_MEMORY_MAX_HTML_SIZE_BYTES=1000000  # Maximum HTML size for regex processing
SECURITY_MEMORY_MAX_REGEX_LENGTH=1000        # Maximum regex pattern length

# Channels Processing Security
SECURITY_CHANNELS_CHANNEL_TIMEOUT=120000   # Per-channel processing timeout (ms)
SECURITY_CHANNELS_ITEM_PROCESSING_TIMEOUT=15000  # Per-item processing timeout (ms)
SECURITY_CHANNELS_PARSER_TIMEOUT=20000     # Parser execution timeout (ms)
SECURITY_CHANNELS_GLOBAL_TIMEOUT=600000    # Global feed processing timeout (ms)

# Parser Security
SECURITY_PARSER_READ_TIMEOUT=30000         # HTML read timeout (ms)
SECURITY_PARSER_FETCH_TIMEOUT=15000        # HTTP fetch timeout (ms)

# Content Sanitizer Security
SECURITY_SANITIZER_URL_CHECK_TIMEOUT=5000  # URL validation timeout (ms)
SECURITY_SANITIZER_MAX_LINK_CHECKS=15      # Maximum concurrent link checks
SECURITY_SANITIZER_MAX_IMAGE_CHECKS=20     # Maximum concurrent image checks
SECURITY_SANITIZER_MAX_VIDEO_CHECKS=10     # Maximum concurrent video checks
SECURITY_SANITIZER_MIN_TEXT_LENGTH=40      # Minimum text length for link blocks